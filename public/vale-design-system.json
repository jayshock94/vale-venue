{
  "$schema": "https://raw.githubusercontent.com/design-tokens/community-group/main/format/dtcg.json",
  "$metadata": {
    "project": "The Vale",
    "address": "1078 South 250 East, Provo, Utah",
    "version": "2.0.0",
    "description": "Single source of truth. No hardcoded values anywhere in the codebase. Everything traces back here.",
    "fonts": {
      "display": "Cormorant Garamond",
      "ui": "Inter",
      "googleFontsUrl": "https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,600;0,700;1,300;1,400;1,600;1,700&family=Inter:wght@400;500;600&display=swap"
    },
    "rules": {
      "serif":        "Headlines ≥ 24px only — hero h1, section h2, pull quotes, testimonials, price and stat display numbers. One italic accent word per card title at any size. Never body copy, captions, labels, or anything read as a sentence.",
      "sans":         "Everything under 24px, without exception — nav, buttons, body copy, captions, labels, eyebrow text, amenity lists, form fields, FAQs, badges, stats labels, footer text, attribution.",
      "size-rule":    "Under 24px = Inter. If someone reads it as a sentence = Inter. No exceptions.",
      "gold":         "Appears max 3 times per page — primary CTA button, price values, one accent word",
      "no-hardcoding":"NEVER hardcode a color, font, or spacing value. Everything must reference a token.",
      "weight-body":  "Body copy: regular (400) minimum — no 300 Light anywhere",
      "weight-nav":   "Nav links: medium (500)",
      "weight-label": "Labels and eyebrows: semibold (600)",
      "weight-card":  "Card titles, section subheadings: medium (500)",
      "weight-serif": "Cormorant Garamond: semibold (600) everywhere — headings h1/h2/h3 and display numbers alike. 700 is loaded but unused; it overrides Cormorant's stroke contrast. 400 only for editorial contexts (testimonials, logo, decorative)."
    }
  },

  "color": {
    "primitive": {
      "gold": {
        "50":  { "$value": "#FBF7F0", "$type": "color" },
        "100": { "$value": "#F3E8D4", "$type": "color" },
        "200": { "$value": "#E6CFA8", "$type": "color" },
        "300": { "$value": "#D4AF78", "$type": "color", "$description": "Sunlit wood grain highlight" },
        "400": { "$value": "#C9A06E", "$type": "color", "$description": "Brand primary — warm champagne gold" },
        "500": { "$value": "#9A7030", "$type": "color" },
        "600": { "$value": "#7C5924", "$type": "color", "$description": "Text accent — dark enough for contrast on cream" },
        "700": { "$value": "#5C4018", "$type": "color" },
        "800": { "$value": "#3C280E", "$type": "color" },
        "900": { "$value": "#201508", "$type": "color" }
      },
      "neutral": {
        "0":   { "$value": "#FFFFFF", "$type": "color" },
        "50":  { "$value": "#F8F7F4", "$type": "color", "$description": "Page background — warm white walls of the main hall" },
        "100": { "$value": "#E8E4DD", "$type": "color" },
        "150": { "$value": "#DEDAD2", "$type": "color" },
        "200": { "$value": "#D0CBC2", "$type": "color", "$description": "Concrete floor mid-tone" },
        "300": { "$value": "#B8B2A8", "$type": "color", "$description": "Stone — border color, dividers" },
        "400": { "$value": "#8C8680", "$type": "color", "$description": "Ghost — placeholder text, secondary labels" },
        "500": { "$value": "#6A6460", "$type": "color", "$description": "Muted — body copy" },
        "600": { "$value": "#464240", "$type": "color" },
        "700": { "$value": "#2A2826", "$type": "color" },
        "800": { "$value": "#181614", "$type": "color", "$description": "Ink — black metal mezzanine frame and railing" },
        "900": { "$value": "#0C0B0A", "$type": "color" }
      },
      "rule": {
        "default": { "$value": "#CAC4BB", "$type": "color" },
        "light":   { "$value": "#E0DBD4", "$type": "color" }
      },
      "sage": {
        "50":  { "$value": "#EAF0EA", "$type": "color" },
        "600": { "$value": "#5A6B5A", "$type": "color" },
        "800": { "$value": "#3D4D3D", "$type": "color" }
      },
      "rust": {
        "50":  { "$value": "#F5EDEA", "$type": "color" },
        "600": { "$value": "#9C4A2A", "$type": "color" },
        "800": { "$value": "#6B3020", "$type": "color" }
      },
      "amber": {
        "50":  { "$value": "#FBF1E4", "$type": "color" },
        "400": { "$value": "#C17B2A", "$type": "color" },
        "800": { "$value": "#5A3810", "$type": "color" }
      }
    },
    "semantic": {
      "surface": {
        "page":     { "$value": "{color.primitive.neutral.50}" },
        "raised":   { "$value": "{color.primitive.neutral.0}" },
        "sunken":   { "$value": "{color.primitive.neutral.100}" },
        "dark":     { "$value": "{color.primitive.neutral.800}" },
        "dark-mid": { "$value": "{color.primitive.neutral.700}" }
      },
      "text": {
        "primary":     { "$value": "{color.primitive.neutral.800}" },
        "secondary":   { "$value": "{color.primitive.neutral.600}" },
        "muted":       { "$value": "{color.primitive.neutral.500}" },
        "ghost":       { "$value": "{color.primitive.neutral.400}" },
        "inverse":     { "$value": "{color.primitive.neutral.50}", "$description": "On dark — cream not white" },
        "accent":      { "$value": "{color.primitive.gold.600}" },
        "accent-dark": { "$value": "{color.primitive.gold.300}" }
      },
      "border": {
        "subtle":  { "$value": "{color.primitive.rule.light}" },
        "default": { "$value": "{color.primitive.rule.default}" },
        "strong":  { "$value": "{color.primitive.neutral.300}" },
        "accent":  { "$value": "{color.primitive.gold.400}" }
      },
      "status": {
        "success-bg":     { "$value": "{color.primitive.sage.50}" },
        "success-text":   { "$value": "{color.primitive.sage.800}" },
        "success-border": { "$value": "{color.primitive.sage.600}" },
        "warning-bg":     { "$value": "{color.primitive.rust.50}" },
        "warning-text":   { "$value": "{color.primitive.rust.800}" },
        "warning-border": { "$value": "{color.primitive.rust.600}" },
        "progress-bg":    { "$value": "{color.primitive.amber.50}" },
        "progress-text":  { "$value": "{color.primitive.amber.800}" }
      }
    }
  },

  "typography": {
    "family": {
      "display": { "$value": "Cormorant Garamond", "$type": "fontFamily" },
      "ui":      { "$value": "Inter",              "$type": "fontFamily" }
    },
    "weight": {
      "regular":  { "$value": 400, "$type": "fontWeight", "$description": "Body copy, body links, captions, input text, tertiary UI text" },
      "medium":   { "$value": 500, "$type": "fontWeight", "$description": "Nav links, card titles, section subheadings" },
      "semibold": { "$value": 600, "$type": "fontWeight", "$description": "Cormorant headings at all sizes and surfaces; labels, eyebrows, buttons, badges; display numbers (stats, prices)" },
      "bold":     { "$value": 700, "$type": "fontWeight", "$description": "Loaded in font stack but not used — available for future one-off needs. Do not assign to recurring classes." }
    },
    "size": {
      "10": { "$value": "11px", "$type": "fontSize", "$description": "Minimum for any label/eyebrow/caption — nav, eyebrows, stat labels, badge text" },
      "11": { "$value": "12px", "$type": "fontSize", "$description": "Small UI — badge text, button sm, secondary labels" },
      "12": { "$value": "13px", "$type": "fontSize", "$description": "Footer text, button md, secondary footnotes" },
      "13": { "$value": "14px", "$type": "fontSize", "$description": "Body copy floor — card descriptions, FAQ answers, button lg" },
      "14": { "$value": "15px", "$type": "fontSize", "$description": "Sub-body, form input text" },
      "15": { "$value": "16px", "$type": "fontSize", "$description": "Section body copy, hero sub-copy" },
      "18": { "$value": "18px", "$type": "fontSize" },
      "20": { "$value": "20px", "$type": "fontSize" },
      "24": { "$value": "24px", "$type": "fontSize", "$description": "Serif threshold — below this, Inter only" },
      "34": { "$value": "34px", "$type": "fontSize", "$description": "Stats bar display numbers" },
      "40": { "$value": "46px", "$type": "fontSize", "$description": "Section h2 — clear visual jump above stats/subheadings" },
      "52": { "$value": "60px", "$type": "fontSize", "$description": "Hero h1 mobile — dominant at viewport entry" },
      "80": { "$value": "80px", "$type": "fontSize", "$description": "Hero h1 desktop" }
    },
    "lineHeight": {
      "tight":   { "$value": 1.1 },
      "snug":    { "$value": 1.25 },
      "normal":  { "$value": 1.5 },
      "relaxed": { "$value": 1.7 },
      "loose":   { "$value": 1.85 }
    },
    "letterSpacing": {
      "tight":   { "$value": "-0.02em" },
      "normal":  { "$value": "0" },
      "btn":     { "$value": "0.06em",  "$description": "All button labels" },
      "label":   { "$value": "0.22em",  "$description": "Form labels" },
      "nav":     { "$value": "0.14em",  "$description": "Nav links" },
      "eyebrow": { "$value": "0.30em",  "$description": "Section eyebrow labels" },
      "badge":   { "$value": "0.12em" },
      "stat":    { "$value": "0.12em" }
    }
  },

  "spacing": {
    "$description": "4px base unit. All values are multiples of 4. Never use arbitrary values like 13px, 22px, 37px.",
    "1":  { "$value": "4px",  "$type": "spacing" },
    "2":  { "$value": "8px",  "$type": "spacing" },
    "3":  { "$value": "12px", "$type": "spacing" },
    "4":  { "$value": "16px", "$type": "spacing" },
    "5":  { "$value": "20px", "$type": "spacing" },
    "6":  { "$value": "24px", "$type": "spacing" },
    "8":  { "$value": "32px", "$type": "spacing" },
    "10": { "$value": "40px", "$type": "spacing" },
    "12": { "$value": "48px", "$type": "spacing" },
    "16": { "$value": "64px", "$type": "spacing" },
    "20": { "$value": "80px", "$type": "spacing" },
    "24": { "$value": "96px", "$type": "spacing" },
    "page-x":            { "$value": "48px", "$description": "Horizontal page padding desktop" },
    "page-x-tablet":     { "$value": "32px" },
    "page-x-mobile":     { "$value": "20px" },
    "section":           { "$value": "96px", "$description": "Between all major page sections" },
    "section-tight":     { "$value": "64px", "$description": "Section header to its component" },
    "nav-height":        { "$value": "64px" },
    "nav-height-mobile": { "$value": "56px" }
  },

  "borderRadius": {
    "none":   { "$value": "0px" },
    "sharp":  { "$value": "0px",   "$description": "Badges, tags, status flags — zero radius" },
    "soft":   { "$value": "2px",   "$description": "Cards — barely perceptible, reads as designed not browser-default" },
    "action": { "$value": "6px",   "$description": "Buttons and interactive controls — 6px, clearly rounded without being pill" },
    "admin":  { "$value": "4px",   "$description": "Admin panels and inputs only" },
    "pill":   { "$value": "100px", "$description": "Primary CTA buttons only — pill shape for maximum distinctiveness" }
  },

  "shadow": {
    "none":       { "$value": "none" },
    "focus-gold": { "$value": "0 0 0 3px rgba(184,137,62,0.22)", "$description": "Gold focus ring — matches gold-400" },
    "focus-ink":  { "$value": "0 0 0 3px rgba(24,22,20,0.15)",  "$description": "Ink focus ring — matches neutral-800" },
    "hover":      { "$value": "0 4px 12px rgba(0,0,0,0.12)",    "$description": "Button lift shadow on hover — applies to gold, ink, outline" }
  },

  "transition": {
    "fast":    { "$value": "130ms ease" },
    "default": { "$value": "150ms ease" },
    "slow":    { "$value": "300ms ease" }
  },

  "component": {
    "button": {
      "$description": "Vale button system. Pill primary, 8px secondary/outline, borderless ghost. Hover: translateY(-1px) + shadow. Active: translateY(0). Ghost only changes text color + arrow nudge.",
      "height-sm":     { "$value": "40px" },
      "height-md":     { "$value": "48px" },
      "height-lg":     { "$value": "56px" },
      "height-mobile": { "$value": "48px", "$description": "Minimum touch target" },

      "padding-sm":    { "$value": "0 20px" },
      "padding-md":    { "$value": "0 28px" },
      "padding-lg":    { "$value": "0 36px" },

      "font-size-sm":   { "$value": "{typography.size.11}" },
      "font-size-md":   { "$value": "{typography.size.12}" },
      "font-size-lg":   { "$value": "{typography.size.13}" },
      "font-weight":    { "$value": "{typography.weight.semibold}" },
      "letter-spacing": { "$value": "{typography.letterSpacing.btn}" },
      "text-transform": { "$value": "uppercase" },

      "radius-primary":   { "$value": "{borderRadius.pill}",   "$description": "Gold CTA only — pill differentiates primary from all other actions on screen" },
      "radius-secondary": { "$value": "{borderRadius.action}", "$description": "Ink and outline — 8px, clearly rounded but not pill" },
      "radius-ghost":     { "$value": "{borderRadius.none}",   "$description": "Ghost has no visible boundary" },

      "hover-translate-y":  { "$value": "-1px" },
      "hover-shadow":       { "$value": "{shadow.hover}" },
      "active-translate-y": { "$value": "0px" },
      "transition":         { "$value": "{transition.fast}" },

      "gap":       { "$value": "{spacing.2}" },
      "group-gap": { "$value": "{spacing.3}" },

      "gold": {
        "$description": "Primary CTA — pill, one per screen view. The action the whole page leads toward. Warm champagne on cream. Elevation is the hover signal — no color change.",
        "radius":     { "$value": "{borderRadius.pill}" },
        "bg":         { "$value": "{color.primitive.gold.400}" },
        "text":       { "$value": "{color.primitive.neutral.800}", "$description": "Ink on gold — 7.3:1 AAA contrast" },
        "bg-hover":   { "$value": "{color.primitive.gold.400}",   "$description": "No color change on hover — translateY + shadow is the signal" },
        "text-hover": { "$value": "{color.primitive.neutral.800}" }
      },

      "ink": {
        "$description": "Secondary action — 8px radius, near-black fill. Same ink as the wordmark and building frame. Check Availability lives here.",
        "radius":     { "$value": "{borderRadius.action}" },
        "bg":         { "$value": "{color.primitive.neutral.800}" },
        "text":       { "$value": "{color.primitive.neutral.50}", "$description": "Cream on dark — never white per brand rule" },
        "bg-hover":   { "$value": "{color.primitive.neutral.700}", "$description": "Lightens slightly; lift + shadow is the primary hover signal" },
        "text-hover": { "$value": "{color.primitive.neutral.50}" }
      },

      "outline": {
        "$description": "Tertiary browse action — 8px radius, transparent until hovered. Stone border, secondary text. Solidifies to ink on hover to confirm action.",
        "radius":       { "$value": "{borderRadius.action}" },
        "bg":           { "$value": "transparent" },
        "text":         { "$value": "{color.primitive.neutral.600}", "$description": "Secondary text — below ink in hierarchy, above muted" },
        "border":       { "$value": "{color.primitive.neutral.300}", "$description": "Stone — visible but quiet, matches system dividers" },
        "bg-hover":     { "$value": "{color.primitive.neutral.800}", "$description": "Fills solid on hover — button solidifies like an ink button, confirms action" },
        "border-hover": { "$value": "{color.primitive.neutral.800}" },
        "text-hover":   { "$value": "{color.primitive.neutral.50}", "$description": "Cream — consistent with ink variant when filled" }
      },

      "ghost": {
        "$description": "Inline wayfinding — no bg, no border. Muted text snaps to ink on hover. No lift or shadow — ghost stays grounded.",
        "bg":          { "$value": "transparent" },
        "text":        { "$value": "{color.primitive.neutral.500}", "$description": "Muted — lowest in hierarchy, reads as linked text not button" },
        "text-hover":  { "$value": "{color.primitive.neutral.800}" },
        "arrow-nudge": { "$value": "4px" }
      },

      "ghost-dark": {
        "$description": "Ghost on dark surfaces (hero, testimonial, footer). Dimmed cream brightens on hover.",
        "text":       { "$value": "rgba(245,240,232,0.40)" },
        "text-hover": { "$value": "rgba(245,240,232,0.85)" }
      }
    },

    "input": {
      "$description": "Bottom-line style on public site. Full border on admin.",
      "height-public":       { "$value": "56px", "$description": "Material 3 standard" },
      "height-admin":        { "$value": "40px" },
      "textarea-min-height": { "$value": "120px" },
      "padding":             { "$value": "16px 0" },
      "font-size":           { "$value": "{typography.size.14}" },
      "font-weight":         { "$value": "{typography.weight.regular}" },
      "label-font-size":     { "$value": "{typography.size.11}" },
      "label-font-weight":   { "$value": "{typography.weight.semibold}" },
      "label-spacing":       { "$value": "{typography.letterSpacing.label}" },
      "label-color":         { "$value": "{color.primitive.gold.600}" },
      "border-default":      { "$value": "{color.primitive.rule.default}" },
      "border-focused":      { "$value": "{color.primitive.gold.400}" },
      "border-error":        { "$value": "{color.primitive.rust.600}" },
      "border-width-default":{ "$value": "1px" },
      "border-width-focused":{ "$value": "2px" },
      "focus-ring":          { "$value": "{shadow.focus-gold}" },
      "field-gap":           { "$value": "{spacing.6}" },
      "group-gap":           { "$value": "{spacing.8}" }
    },

    "nav": {
      "height":             { "$value": "{spacing.nav-height}" },
      "height-mobile":      { "$value": "{spacing.nav-height-mobile}" },
      "padding-x":          { "$value": "{spacing.page-x}" },
      "bg-light":           { "$value": "{color.semantic.surface.page}" },
      "bg-dark":            { "$value": "transparent" },
      "border-light":       { "$value": "{color.semantic.border.subtle}" },
      "link-color-light":   { "$value": "{color.semantic.text.muted}" },
      "link-color-dark":    { "$value": "rgba(245,240,232,0.50)" },
      "link-active-light":  { "$value": "{color.semantic.text.primary}" },
      "link-active-dark":   { "$value": "{color.semantic.text.inverse}" },
      "link-active-border": { "$value": "{color.primitive.gold.400}" },
      "link-spacing":       { "$value": "{spacing.8}" },
      "font-size":          { "$value": "{typography.size.10}" },
      "letter-spacing":     { "$value": "{typography.letterSpacing.nav}" }
    },

    "section": {
      "gap":                    { "$value": "{spacing.section}" },
      "gap-tight":              { "$value": "{spacing.section-tight}" },
      "padding-x":              { "$value": "{spacing.page-x}" },
      "padding-x-mobile":       { "$value": "{spacing.page-x-mobile}" },
      "hero-min-height":        { "$value": "100vh" },
      "hero-padding-top":       { "$value": "120px" },
      "page-hero-height":       { "$value": "240px" },
      "page-hero-height-mobile":{ "$value": "200px" }
    },

    "pricing-table": {
      "header-bg":       { "$value": "#FAF7F2" },
      "row-alt-bg":      { "$value": "#FDFAF6" },
      "row-border":      { "$value": "{color.semantic.border.subtle}" },
      "row-height":      { "$value": "56px" },
      "header-height":   { "$value": "40px" },
      "price-font":      { "$value": "{typography.family.display}" },
      "price-size":      { "$value": "{typography.size.18}" },
      "peak-size":       { "$value": "{typography.size.20}" },
      "peak-color":      { "$value": "{color.primitive.gold.400}" }
    },

    "testimonial": {
      "bg":          { "$value": "{color.semantic.surface.dark}" },
      "quote-size":  { "$value": "{typography.size.20}" },
      "quote-color": { "$value": "rgba(245,240,232,0.85)" },
      "attr-color":  { "$value": "rgba(245,240,232,0.30)" },
      "rule-color":  { "$value": "rgba(201,160,110,0.30)" }
    },

    "stats-bar": {
      "height":        { "$value": "88px" },
      "number-size":   { "$value": "{typography.size.34}" },
      "number-font":   { "$value": "{typography.family.display}" },
      "number-weight": { "$value": "{typography.weight.semibold}" },
      "label-size":    { "$value": "{typography.size.10}" },
      "label-spacing": { "$value": "{typography.letterSpacing.stat}" }
    },

    "badge": {
      "height":         { "$value": "20px" },
      "padding":        { "$value": "0 8px" },
      "font-size":      { "$value": "{typography.size.10}" },
      "font-weight":    { "$value": "{typography.weight.semibold}" },
      "letter-spacing": { "$value": "{typography.letterSpacing.badge}" },
      "border-radius":  { "$value": "{borderRadius.sharp}" }
    },

    "flag": {
      "border-width":  { "$value": "3px", "$description": "Left side only. No border-radius." },
      "border-radius": { "$value": "0" },
      "padding":       { "$value": "12px 16px" },
      "font-size":     { "$value": "{typography.size.12}" },
      "font-weight":   { "$value": "{typography.weight.regular}" }
    },

    "faq": {
      "row-min-height":  { "$value": "56px" },
      "padding":         { "$value": "20px 0" },
      "question-size":   { "$value": "{typography.size.14}" },
      "question-weight": { "$value": "{typography.weight.medium}" },
      "answer-size":     { "$value": "{typography.size.13}" },
      "answer-weight":   { "$value": "{typography.weight.regular}" }
    },

    "touch-target": {
      "min-size": { "$value": "48px", "$description": "Material 3 minimum. All interactive elements on mobile." }
    },

    "admin": {
      "$description": "Separate design language — functional, neutral, gold accents only",
      "nav-height":    { "$value": "52px" },
      "sidebar-width": { "$value": "200px" },
      "panel-bg":      { "$value": "#FFFFFF" },
      "panel-border":  { "$value": "1px solid #E0E0E0" },
      "panel-radius":  { "$value": "{borderRadius.admin}" },
      "panel-padding": { "$value": "20px 24px" },
      "page-bg":       { "$value": "#F8F8F8" },
      "text-primary":  { "$value": "#1A1A1A" },
      "text-muted":    { "$value": "#888888" },
      "border-color":  { "$value": "#E0E0E0" },
      "accent":        { "$value": "{color.primitive.gold.400}" }
    }
  },

  "layout": {
    "$description": "Asymmetric editorial layouts. Never use repeat(3, 1fr) for content sections.",
    "hero":           { "columns": "1fr 320px",                  "gap": "72px" },
    "section-header": { "columns": "1fr 480px",                  "gap": "80px" },
    "event-cards":    { "columns": "1.8fr 1fr",                  "description": "Large dominant + two stacked" },
    "pricing-table":  { "columns": "1fr 70px 100px 100px 110px", "description": "Package | Hours | Mon-Wed | Thu | Fri-Sat" },
    "amenity-grid":   { "columns": "1fr 1fr" },
    "footer":         { "columns": "1.5fr 1fr 1fr 1fr" }
  },

  "max-width": {
    "body-text": { "$value": "680px" },
    "content":   { "$value": "1280px" },
    "form":      { "$value": "600px" },
    "pricing":   { "$value": "840px" }
  },

  "breakpoint": {
    "mobile":  { "$value": "375px" },
    "tablet":  { "$value": "768px", "$description": "Nav collapses to hamburger" },
    "laptop":  { "$value": "1024px" },
    "desktop": { "$value": "1280px" }
  },

  "content": {
    "venue": {
      "name":           "The Vale",
      "full-name":      "The Vale at Ten Seventy-Eight",
      "tagline":        "A modern event space at the base of the Wasatch mountains.",
